{
  "name": "iflow-settings-editor",
  "version": "1.10.1",
  "description": "一个用于编辑 iFlow CLI 配置文件的桌面应用程序。",
  "main": "src/main/index.js",
  "author": "上海潘哆呐科技有限公司",
  "repository": {
    "url": "https://github.com/yuentao/iFlow-Settings-Editor-GUI.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "type-check": "vue-tsc --noEmit",
    "build": "vite build",
    "start": "electron .",
    "electron:dev": "concurrently \"vite\" \"electron . --dev\"",
    "electron:start": "vite build && electron .",
    "pack": "electron-builder --dir",
    "build:win": "vite build && electron-builder --win",
    "build:win64": "vite build && electron-builder --win --x64",
    "build:win32": "vite build && electron-builder --win --ia32",
    "build:win-portable": "vite build && electron-builder --win portable",
    "build:win-installer": "vite build && electron-builder --win nsis",
    "build:mac": "vite build && electron-builder --mac",
    "build:mac64": "vite build && electron-builder --mac --x64",
    "build:mac-arm": "vite build && electron-builder --mac --arm64",
    "build:mac-dmg": "vite build && electron-builder --mac dmg",
    "build:mac-zip": "vite build && electron-builder --mac zip",
    "dist": "vite build && electron-builder",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run"
  },
  "build": {
    "appId": "com.iflow.settings-editor",
    "productName": "iFlow Settings Editor",
    "copyright": "Copyright © 2026 上海潘哆呐科技有限公司",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": null,
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon/icon.ico"
      },
      {
        "from": "build/icon.icns",
        "to": "icon/icon.icns"
      }
    ],
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "updateChecker.js",
      "autoUpdater.js"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "dmg": {
      "title": "${productName}-${version}",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "iFlow Settings Editor",
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  },
  "devDependencies": {
    "@icon-park/vue-next": "^1.4.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "happy-dom": "^20.9.0",
    "less": "^4.6.4",
    "less-loader": "^12.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "vue": "^3.4.0",
    "vue-tsc": "^3.2.7"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@vueuse/core": "^14.2.1",
    "adm-zip": "^0.5.17",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "marked": "^18.0.2",
    "pinia": "^3.0.4",
    "vue-i18n": "^9.14.5"
  }
}
